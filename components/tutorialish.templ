package components

import "github.com/Norrun/feedmixer/internal/feed"

templ ListItems(feeditems []feed.DisplayItem) {
	<div id="feed-item-list" class="feed-item-list"> 
	for _, item := range feeditems {
		<div class="feed-item">
			<h2>{item.Title}</h2>
			<p>{item.Description}</p>
			<a href={templ.SafeURL(item.Url)}>{item.Url}</a>
		</div>
	}// for loop
	<!-- looks like it -->
	</div>
}